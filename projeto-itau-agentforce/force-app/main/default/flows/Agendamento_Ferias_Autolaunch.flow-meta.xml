    <decisions>
        <name>Validar_Ordem_Datas_Iniciais</name>
        <label>Inicio antes do retorno (entrada)</label>
        <locationX>350</locationX>
        <locationY>50</locationY>
        <defaultConnector>
            <targetReference>Ajustar_Ano_Datas</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Ordem OK ou incompleto</defaultConnectorLabel>
        <rules>
            <name>Entrada_Datas_Invertidas</name>
            <conditionLogic>1 AND 2 AND 3</conditionLogic>
            <conditions>
                <leftValueReference>varDataInicio</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varDataRetorno</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varDataInicio</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>varDataRetorno</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Datas_Invertidas</targetReference>
            </connector>
            <label>Inicio depois do retorno</label>
        </rules>
    </decisions>

