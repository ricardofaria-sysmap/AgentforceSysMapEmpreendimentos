    <decisions>
        <name>Valida_CLT</name>
        <label>Validacoes CLT</label>
        <locationX>600</locationX>
        <locationY>520</locationY>
        <defaultConnector>
            <targetReference>Decision_Abono</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>OK</defaultConnectorLabel>
        <rules>
            <name>R_Datas_Invertidas</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varDataInicio</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>varDataRetorno</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Datas_Invertidas</targetReference>
            </connector>
            <label>Inicio depois do retorno</label>
        </rules>
        <rules>
            <name>R0_Data_No_Passado</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varDataInicio</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Data_Passado</targetReference>
            </connector>
            <label>Data no passado</label>
        </rules>
        <rules>
            <name>R1_Aviso_30d</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxDiasAteInicio</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>30.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Aviso_30d</targetReference>
            </connector>
            <label>Aviso 30d</label>
        </rules>
        <rules>
            <name>R2_Saldo_Insuficiente</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxDiasSolicitados</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Saldo_Atual.Dias_Disponiveis__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Saldo</targetReference>
            </connector>
            <label>Saldo insuficiente</label>
        </rules>
        <rules>
            <name>R3_Minimo_5</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxDiasSolicitados</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Minimo_5</targetReference>
            </connector>
            <label>Minimo 5 dias</label>
        </rules>
        <rules>
            <name>R4_Concessivo</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varDataRetorno</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Saldo_Atual.Periodo_Concessivo_Fim__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Concessivo</targetReference>
            </connector>
            <label>Fora do concessivo</label>
        </rules>
        <rules>
            <name>R5_Dia_Semana_Invalido</name>
            <conditionLogic>1 OR 2 OR 3 OR 4</conditionLogic>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>6.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>7.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Dia_Semana</targetReference>
            </connector>
            <label>Qui/Sex/Sab/Dom</label>
        </rules>
        <rules>
            <name>R6_Inicio_Eh_Feriado</name>
            <conditionLogic>1 AND 2</conditionLogic>
            <conditions>
                <leftValueReference>Get_Feriado_Range.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Feriado_Range.Data__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>varDataInicio</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Inicio_Feriado</targetReference>
            </connector>
            <label>Inicio eh feriado</label>
        </rules>
        <rules>
            <name>R7_Vespera_Feriado</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Feriado_Range.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Vespera_Feriado</targetReference>
            </connector>
            <label>Vespera de feriado</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Abono</name>
        <label>Validar abono se solicitado</label>
        <locationX>600</locationX>
        <locationY>700</locationY>
        <defaultConnector>
            <targetReference>Criar_Case</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>OK, criar Case</defaultConnectorLabel>
        <rules>
            <name>Abono_Dias_Invalido</name>
            <conditionLogic>1 AND 2</conditionLogic>
            <conditions>
                <leftValueReference>varVenderAbono</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varDiasAbono</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Abono_Dias_Invalido</targetReference>
            </connector>
            <label>Abono true sem dias</label>
        </rules>
        <rules>
            <name>Abono_Excede_Limite</name>
            <conditionLogic>1 AND 2</conditionLogic>
            <conditions>
                <leftValueReference>varVenderAbono</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varDiasAbono</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>fxLimiteAbono</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Abono</targetReference>
            </connector>
            <label>Abono excede 1/3</label>
        </rules>
    </decisions>

    <formulas>
        <name>fxAssuntoCase</name>
        <dataType>String</dataType>
        <expression>"Pedido de Ferias - " &amp; TEXT({!varDataInicio}) &amp; " a " &amp; TEXT({!varDataRetorno})</expression>
    </formulas>
    <formulas>
        <name>fxDiaSemanaInicio</name>
        <dataType>Number</dataType>
        <expression>WEEKDAY({!varDataInicio})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxDiasAteInicio</name>
        <dataType>Number</dataType>
        <expression>{!varDataInicio} - TODAY()</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxDiasSolicitados</name>
        <dataType>Number</dataType>
        <expression>{!varDataRetorno} - {!varDataInicio} + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxLimiteAbono</name>
        <dataType>Number</dataType>
        <expression>FLOOR({!Get_Saldo_Atual.Dias_Direito__c} / 3) - BLANKVALUE({!Get_Saldo_Atual.Dias_Abono_Vendidos__c}, 0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxDataInicioMais2</name>
        <dataType>Date</dataType>
        <expression>{!varDataInicio} + 2</expression>
    </formulas>
    <formulas>
        <name>Formula_UserIdResolvido</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!varUserId}), {!$User.Id}, {!varUserId})</expression>
    </formulas>
    <formulas>
        <name>Formula_MensagemSucesso</name>
        <dataType>String</dataType>
        <expression>"Agendamento confirmado! Periodo de " &amp; {!Formula_DataInicioFormatada} &amp; " a " &amp; {!Formula_DataRetornoFormatada} &amp; ". Protocolo: " &amp; {!Get_Case_Criado.CaseNumber} &amp; ". O pedido foi enviado ao seu gestor para aprovacao."</expression>
    </formulas>
    <formulas>
        <name>Formula_DataInicioFormatada</name>
        <dataType>String</dataType>
        <expression>TEXT(DAY({!varDataInicio})) &amp; "/" &amp; TEXT(MONTH({!varDataInicio})) &amp; "/" &amp; TEXT(YEAR({!varDataInicio}))</expression>
    </formulas>
    <formulas>
        <name>Formula_DataRetornoFormatada</name>
        <dataType>String</dataType>
        <expression>TEXT(DAY({!varDataRetorno})) &amp; "/" &amp; TEXT(MONTH({!varDataRetorno})) &amp; "/" &amp; TEXT(YEAR({!varDataRetorno}))</expression>
    </formulas>
    <formulas>
        <name>Formula_DataInicioAjustada</name>
        <dataType>Date</dataType>
        <expression>IF(
    OR(ISNULL({!varDataInicio}), {!varDataInicio} &gt;= TODAY()),
    {!varDataInicio},
    DATE(YEAR({!varDataInicio}) + (YEAR(TODAY()) - YEAR({!varDataInicio})) +
         IF(DATE(YEAR(TODAY()), MONTH({!varDataInicio}), DAY({!varDataInicio})) &lt; TODAY(), 1, 0),
         MONTH({!varDataInicio}), DAY({!varDataInicio}))
)</expression>
    </formulas>
    <formulas>
        <name>Formula_DataRetornoAjustada</name>
        <dataType>Date</dataType>
        <expression>IF(
    OR(ISNULL({!varDataRetorno}), {!varDataRetorno} &gt;= TODAY()),
    {!varDataRetorno},
    DATE(YEAR({!varDataRetorno}) + (YEAR(TODAY()) - YEAR({!varDataRetorno})) +
         IF(DATE(YEAR(TODAY()), MONTH({!varDataRetorno}), DAY({!varDataRetorno})) &lt; TODAY(), 1, 0),
         MONTH({!varDataRetorno}), DAY({!varDataRetorno}))
)</expression>
    </formulas>

