            <field>Vender_Abono__c</field>
            <value>
                <elementReference>varVenderAbono</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Dias_Abono__c</field>
            <value>
                <elementReference>varDiasAbono</elementReference>
            </value>
        </inputAssignments>
