    <screens>
        <name>Tela_Sem_Saldo</name>
        <label>Sem saldo vigente</label>
        <locationX>300</locationX>
        <locationY>300</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>Display_Sem_Saldo</name>
            <fieldText>&lt;p&gt;&lt;strong&gt;Não encontramos um saldo de férias vigente em seu nome.&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Entre em contato com o RH pelo canal oficial para regularizar sua situação antes de agendar.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <screens>
        <name>Tela_Boas_Vindas</name>
        <label>Saldo e datas do pedido</label>
        <locationX>600</locationX>
        <locationY>450</locationY>
        <allowBack>true</allowBack>
        <allowFinish>false</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Get_Feriado_Range</targetReference>
        </connector>
        <fields>
            <name>Display_Cabecalho</name>
            <fieldText>{!textCabecalho}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Display_Regras_Rodape</name>
            <fieldText>{!textRegrasEHint}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>feriasDatePicker</name>
            <extensionName>c:feriasDateRangePicker</extensionName>
