            <field>Aprovacao_Gestor__c</field>
            <value>
                <stringValue>Pendente</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Data_Inicio_Ferias__c</field>
            <value>
                <elementReference>varDataInicio</elementReference>
