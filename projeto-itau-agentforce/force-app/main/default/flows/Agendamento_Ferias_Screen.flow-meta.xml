        </fields>
        <fields>
            <name>Display_Saldo_Compact</name>
            <fieldText>{!textSaldoCompact}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <nextOrFinishButtonLabel>Validar e continuar</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <screens>
        <name>Tela_Abono</name>
        <label>Abono Pecuniário</label>
        <locationX>500</locationX>
        <locationY>900</locationY>
        <allowBack>true</allowBack>
        <allowFinish>false</allowFinish>
        <allowPause>false</allowPause>
        <backButtonLabel>Voltar</backButtonLabel>
        <connector>
            <targetReference>Set_Abono_Vars</targetReference>
        </connector>
        <fields>
            <name>Display_Abono_Info</name>
            <fieldText>{!textAbonoInfo}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>venderAbono</name>
            <dataType>Boolean</dataType>
            <fieldText>Desejo converter parte das minhas ferias em abono pecuniario</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
            <defaultValue>
                <elementReference>varVenderAbono</elementReference>
            </defaultValue>
        </fields>
        <fields>
            <name>diasAbono</name>
            <dataType>Number</dataType>
            <fieldText>Quantos dias deseja converter em abono?</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>false</isRequired>
            <scale>0</scale>
            <defaultValue>
                <elementReference>varDiasAbono</elementReference>
            </defaultValue>
        </fields>
        <nextOrFinishButtonLabel>Continuar</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <screens>
        <name>Tela_Confirmacao</name>
        <label>Confirmacao</label>
        <locationX>600</locationX>
        <locationY>1000</locationY>
        <allowBack>true</allowBack>
        <allowFinish>false</allowFinish>
        <allowPause>false</allowPause>
        <backButtonLabel>Voltar</backButtonLabel>
        <connector>
            <targetReference>Criar_Case</targetReference>
        </connector>
        <fields>
            <name>Display_Resumo</name>
            <fieldText>{!textResumo}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>confirmoDados</name>
            <dataType>Boolean</dataType>
            <fieldText>Confirmo que todas as informacoes acima estao corretas.</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <nextOrFinishButtonLabel>Enviar para aprovacao</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <screens>
        <name>Tela_Sucesso</name>
        <label>Sucesso</label>
        <locationX>600</locationX>
        <locationY>1300</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>Display_Sucesso</name>
            <fieldText>{!textSucesso}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <screens>
        <name>Tela_Erro</name>
        <label>Erro de Validação</label>
        <locationX>500</locationX>
        <locationY>700</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Tela_Boas_Vindas</targetReference>
        </connector>
        <fields>
            <name>Display_Erro</name>
            <fieldText>{!textErro}</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <nextOrFinishButtonLabel>Corrigir datas</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <start>
        <locationX>350</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Saldo_Atual</targetReference>
        </connector>
    </start>

    <textTemplates>
        <name>textCabecalho</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;h2&gt;Olá, {!$User.FirstName}! Vamos agendar suas férias?&lt;/h2&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textSaldo</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong&gt;Seu saldo atual:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Regime: {!Get_Saldo_Atual.Regime_Contratacao__c}&lt;/li&gt;&lt;li&gt;Direito no período aquisitivo: &lt;strong&gt;{!Get_Saldo_Atual.Dias_Direito__c} dias&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;Já tirados: {!Get_Saldo_Atual.Dias_Tirados__c} dias&lt;/li&gt;&lt;li&gt;Disponíveis: &lt;strong&gt;{!Get_Saldo_Atual.Dias_Disponiveis__c} dias&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;Prazo concessivo: até {!Get_Saldo_Atual.Periodo_Concessivo_Fim__c}&lt;/li&gt;&lt;/ul&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textSaldoCompact</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong&gt;Seu saldo (resumo):&lt;/strong&gt; {!Get_Saldo_Atual.Regime_Contratacao__c} — direito &lt;strong&gt;{!Get_Saldo_Atual.Dias_Direito__c}&lt;/strong&gt;d, tirados {!Get_Saldo_Atual.Dias_Tirados__c}d, &lt;strong&gt;disponíveis {!Get_Saldo_Atual.Dias_Disponiveis__c}&lt;/strong&gt;d — concessivo até {!Get_Saldo_Atual.Periodo_Concessivo_Fim__c}.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textRegrasEHint</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong&gt;Regras CLT (resumo):&lt;/strong&gt; mínimo 5 dias corridos; início de segunda a quinta; aviso de 30 dias; evitar vésperas de feriado.&lt;/p&gt;&lt;p style="color:#0176d3"&gt;&lt;strong&gt;Importante:&lt;/strong&gt; o botão &lt;em&gt;Validar e continuar&lt;/em&gt; fica no &lt;strong&gt;rodapé desta janela&lt;/strong&gt;. Após preencher as datas, &lt;strong&gt;deslize até ao fim&lt;/strong&gt; da página (ou deste painel) para o ver.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textAbonoInfo</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong&gt;Abono pecuniário:&lt;/strong&gt; você pode converter até 1/3 do seu direito em dinheiro.&lt;/p&gt;&lt;p&gt;Limite disponível: &lt;strong&gt;{!fxLimiteAbono} dias&lt;/strong&gt;.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textResumo</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong&gt;Confira os dados do seu pedido:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Início: {!varDataInicio}&lt;/li&gt;&lt;li&gt;Retorno: {!varDataRetorno}&lt;/li&gt;&lt;li&gt;Total: {!fxDiasSolicitados} dias corridos&lt;/li&gt;&lt;li&gt;Vender abono: {!varVenderAbono}&lt;/li&gt;&lt;li&gt;Dias em abono: {!varDiasAbono}&lt;/li&gt;&lt;li&gt;Gestor aprovador: {!Get_Manager.Name}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;Ao enviar, o pedido irá para aprovação do seu gestor.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textSucesso</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;h2&gt;Pedido enviado com sucesso!&lt;/h2&gt;&lt;p&gt;Seu pedido foi encaminhado ao gestor para aprovação.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Protocolo:&lt;/strong&gt; {!Criar_Case}&lt;/p&gt;&lt;p&gt;Assim que for aprovado, você receberá um email de confirmação. Um lembrete será enviado 5 dias antes do início das férias.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>textErro</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;div style="color:#c23934"&gt;&lt;p&gt;&lt;strong&gt;Não foi possível validar seu pedido.&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;{!varMensagemErro}&lt;/p&gt;&lt;/div&gt;</text>
    </textTemplates>

    <variables>
        <name>varUserId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <value>
            <elementReference>$User.Id</elementReference>
        </value>
    </variables>
    <variables>
        <name>varDataInicio</name>
        <dataType>Date</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>varDataRetorno</name>
        <dataType>Date</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>varVenderAbono</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>varDiasAbono</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
        <value>
            <numberValue>0.0</numberValue>
        </value>
    </variables>
    <variables>
        <name>varMensagemErro</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>varCaseId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
</Flow>
