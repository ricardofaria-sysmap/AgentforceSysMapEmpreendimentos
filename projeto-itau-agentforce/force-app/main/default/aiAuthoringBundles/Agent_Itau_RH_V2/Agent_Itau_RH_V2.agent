system:
    instructions: "Você é o assistente virtual de RH do Itaú (I-Connecta). Fale sempre em português brasileiro, tom cordial e profissional. Seja conciso (2-4 frases por resposta). Nunca invente regras; quando não souber, transfira para atendimento humano. Ao citar uma regra, sempre informe a fonte legal (ex: conforme art. 143 CLT). Não informe dados de outros colaboradores."
    messages:
        welcome: "Olá! Sou o assistente virtual de RH do Itaú. Posso consultar políticas (férias, abono, home office) e ajudar você a agendar suas férias. Como posso ajudar?"
        error: "Desculpe, não consegui processar sua solicitação agora. Vou transferir para um atendente humano."

config:
    developer_name: "Agent_Itau_RH_V2"
    agent_label: "Agent Itau RH (V2 - Agent Script)"
    description: "Assistente virtual do I-Connecta (Itau) para consultas de politicas de RH (ferias CLT/PJ, abono, home office) e agendamento de ferias com validacoes deterministicas em Agent Script."
    default_agent_user: "agent_itau_rh@00dhp00000kp2281242825705.ext"

variables:
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "Id do MessagingEndUser da sessao atual de chat."
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "Id da MessagingSession usada para roteamento."
    ContactId: linked string
        source: @MessagingEndUser.ContactId
        description: "Contact Id vinculado ao end user da sessao."
    ColaboradorUserId: mutable string
        description: "User Id (Salesforce) do colaborador solicitante - preenchido pelo planner ou via Apex de resolucao Contact->User."
    DataInicio: mutable string
        description: "Data de inicio das ferias solicitada pelo colaborador (formato ISO YYYY-MM-DD)."
    DataRetorno: mutable string
        description: "Data de retorno das ferias (formato ISO YYYY-MM-DD)."
    VenderAbono: mutable boolean
        description: "True se o colaborador quer vender abono pecuniario."
    DiasAbono: mutable number
        description: "Quantidade de dias de abono a vender (0 se nao estiver vendendo)."
    TentativasAgendamento: mutable number
        description: "Contador de tentativas de agendamento falhas (para escalacao apos 3)."
    UltimoCaseNumber: mutable string
        description: "CaseNumber retornado apos agendamento bem sucedido."

language:
    default_locale: "pt_BR"
    additional_locales: ""
    all_additional_locales: False

start_agent topic_selector:
    label: "Roteador de Entrada"
    description: "Analisa a intencao do colaborador e escolhe entre consulta de politica, agendamento de ferias ou escalacao."

    reasoning:
        instructions: ->
            | Analise a mensagem inicial do colaborador.
              - Se for DUVIDA sobre politica ou regra (ex: quantos dias de ferias tenho direito, como funciona abono), va para Consulta Politicas RH.
              - Se for INTENCAO DE AGENDAR (ex: quero tirar ferias, preciso marcar, agendar minhas ferias), va para Agendamento de Ferias.
              - Se pedir HUMANO ou expressar frustracao, va para Escalation.
              - Se ambiguo, va para Ambiguous Question para pedir clarificacao.
        actions:
            go_to_consulta_politicas: @utils.transition to @topic.consulta_politicas_rh
                description: "Usar quando o colaborador tem duvida sobre politica de RH."
            go_to_agendamento: @utils.transition to @topic.agendamento_ferias
                description: "Usar quando o colaborador quer agendar ferias."
            go_to_escalation: @utils.transition to @topic.escalation
                description: "Usar quando o colaborador pede atendimento humano."
            go_to_ambiguous_question: @utils.transition to @topic.ambiguous_question
                description: "Usar quando a intencao nao esta clara."


topic consulta_politicas_rh:
    label: "Consulta Politicas RH"
    description: "Responde duvidas sobre politicas de RH do Itau (ferias CLT/PJ, abono pecuniario, fracionamento, beneficios durante ferias, home office) consultando exclusivamente os artigos publicados na base de Knowledge."

    actions:
        consultar_politicas:
            description: "Busca artigos de Knowledge publicados (PublishStatus Online) por palavra-chave. Retorna ate 5 artigos com titulo, resumo, conteudo e fonte legal."
            target: "apex://ConsultarPoliticasRH"
            inputs:
                query: string
                    description: "Palavra-chave de busca derivada da pergunta do usuario. Ex: ferias, abono pecuniario, home office."
                    is_user_input: True
            outputs:
                success: boolean
                    description: "True se encontrou ao menos 1 artigo."
                message: string
                    description: "Mensagem quando nao encontra (sugestao de nova palavra-chave)."
                totalEncontrados: number
                    description: "Numero de artigos retornados."

    reasoning:
        instructions: ->
            | Voce responde duvidas sobre politicas internas de RH do Banco Itau.
              Consulte SEMPRE a base de Knowledge antes de responder. Nunca invente regras.
              Ao citar uma regra, informe a fonte legal (ex: conforme art. 143 CLT).
              Responda em 2-3 paragrafos, nao despeje o artigo inteiro.
              Passos:
              1. Extraia a palavra-chave principal da pergunta.
              2. Execute consultar_politicas com essa palavra-chave.
              3. Se encontrar artigos, cite os mais relevantes com fonte legal.
              4. Se nao encontrar, diga que nao localizou e sugira transferir para atendimento humano.
              5. Se o colaborador demonstrar intencao de AGENDAR ferias, transfira para o subagente Agendamento.
        actions:
            pesquisar: @actions.consultar_politicas
                description: "Busca politicas por palavra-chave."
            ir_para_agendamento: @utils.transition to @topic.agendamento_ferias
                description: "Usar quando o colaborador manifesta intencao de marcar ou agendar ferias."
            escalar: @utils.transition to @topic.escalation
                description: "Usar quando o colaborador pede para falar com humano."


topic agendamento_ferias:
    label: "Agendamento de Ferias"
    description: "Guia o colaborador pelo agendamento de ferias validando regras CLT (30 dias aviso, saldo, minimo 5 dias, fora do concessivo, sex/sab/dom, vespera de feriado, abono 1/3) via Flow deterministico. Cria Case Pedido_Ferias e submete aprovacao automatica ao gestor direto."

    actions:
        consultar_saldo:
            description: "Consulta saldo de ferias vigente do colaborador. Retorna dias disponiveis, regime (CLT ou PJ), periodo aquisitivo e limite do concessivo."
            target: "apex://ConsultarSaldoFerias"
            inputs:
                userId: string
                    description: "User Id do colaborador. Usar @variables.ColaboradorUserId."
            outputs:
                success: boolean
                    description: "True se encontrou saldo vigente."
                diasDireito: number
                    description: "Dias de direito (30 para CLT sem faltas, 20 para PJ)."
                diasDisponiveis: number
                    description: "Dias que ainda podem ser agendados."
                diasTirados: number
                    description: "Dias ja gozados."
                diasAbonoVendidos: number
                    description: "Dias de abono ja vendidos."
                regime: string
                    description: "CLT ou PJ."
                message: string
                    description: "Mensagem de erro se success=False."

        agendar_ferias:
            description: "Executa o agendamento: valida regras CLT, cria Case Pedido_Ferias, submete aprovacao do gestor. Retorna sucesso e CaseNumber, ou falha com mensagem de erro especifica."
            target: "flow://Agendamento_Ferias_Autolaunch"
            inputs:
                varUserId: string
                    description: "User Id do colaborador. Usar @variables.ColaboradorUserId."
                varDataInicio: string
                    description: "Data de inicio no formato ISO YYYY-MM-DD."
                varDataRetorno: string
                    description: "Data de retorno no formato ISO YYYY-MM-DD."
                varVenderAbono: boolean
                    description: "True se o colaborador quer vender abono pecuniario."
                varDiasAbono: number
                    description: "Quantidade de dias de abono (0 se nao esta vendendo)."
            outputs:
                varSucesso: boolean
                    description: "True se o agendamento foi criado e aprovacao submetida."
                varMensagemErro: string
                    description: "Mensagem especifica quando varSucesso=False (qual regra foi violada)."
                varCaseNumber: string
                    description: "Numero do Case criado (ex: 00001234)."
                varCaseId: string
                    description: "Id interno do Case."

    reasoning:
        instructions: ->
            if @variables.TentativasAgendamento >= 3:
                | O agendamento falhou 3 vezes. Vou transferir para um atendente humano resolver sua solicitacao.
                transition to @topic.escalation

            if @variables.UltimoCaseNumber != "":
                | Seu agendamento foi confirmado no Case {!@variables.UltimoCaseNumber}.
                  Voce recebera o e-mail de aprovacao do seu gestor em ate 48h uteis.
                  Se precisar de algo mais, estou a disposicao.
            else:
                | Voce e o assistente de agendamento de ferias do Itau. Fluxo:
                  1. Se @variables.ColaboradorUserId esta vazio, peca ao colaborador para confirmar seu nome ou email para identificacao.
                  2. Execute consultar_saldo com userId = @variables.ColaboradorUserId para obter contexto do saldo e regime.
                  3. Informe ao colaborador quantos dias disponiveis ele tem e peca as datas (formato DD/MM/AAAA). Internamente, converta para ISO YYYY-MM-DD e salve via capturar_datas.
                  4. Pergunte se quer vender abono (sim/nao) e, se sim, quantos dias (maximo 1/3 do direito). Salve via capturar_abono.
                  5. Confirme os dados com o usuario antes de executar.
                  6. Execute executar_agendamento. Se falhar, leia varMensagemErro e explique o ajuste necessario. Incremente @variables.TentativasAgendamento.
                  7. Se sucesso, UltimoCaseNumber ja fica preenchido pelo set da action; confirme o protocolo com o colaborador.
        actions:
            pesquisar_saldo: @actions.consultar_saldo
                description: "Consultar o saldo vigente do colaborador antes de agendar."
                with userId = @variables.ColaboradorUserId
            executar_agendamento: @actions.agendar_ferias
                description: "Executar o agendamento apos datas e abono confirmados."
                with varUserId = @variables.ColaboradorUserId
                with varDataInicio = @variables.DataInicio
                with varDataRetorno = @variables.DataRetorno
                with varVenderAbono = @variables.VenderAbono
                with varDiasAbono = @variables.DiasAbono
                set @variables.UltimoCaseNumber = @outputs.varCaseNumber
            capturar_datas: @utils.setVariables
                description: "Salvar as datas de inicio e retorno que o colaborador informou (convertidas para ISO YYYY-MM-DD)."
                with DataInicio = ...
                with DataRetorno = ...
            capturar_abono: @utils.setVariables
                description: "Salvar a decisao do colaborador sobre abono pecuniario."
                with VenderAbono = ...
                with DiasAbono = ...
            capturar_colaborador: @utils.setVariables
                description: "Salvar o User Id do colaborador solicitante (ex: quando identificado via email/nome)."
                with ColaboradorUserId = ...
            voltar_politicas: @utils.transition to @topic.consulta_politicas_rh
                description: "Usar quando o colaborador muda o assunto para duvida sobre politica (nao quer mais agendar)."
            escalar: @utils.transition to @topic.escalation
                description: "Usar apos 3 tentativas falhas ou quando o colaborador pede humano."


topic escalation:
    label: "Escalation"
    description: "Transfere para um atendente humano de RH quando o colaborador explicitamente pede ou apos 3 tentativas falhas de agendamento."

    reasoning:
        instructions: ->
            | Peca desculpas pelo inconveniente e informe que um atendente humano de RH vai assumir o atendimento em breve.
              Resuma em uma frase o que o colaborador estava tentando fazer, para que o humano tenha contexto.
        actions:
            escalate_to_human: @utils.escalate
                description: "Transferir para atendente humano de RH."


topic ambiguous_question:
    label: "Pergunta Ambigua"
    description: "Quando a intencao do colaborador nao esta clara, pede clarificacao sobre se ele quer consulta de politica ou agendamento de ferias."

    reasoning:
        instructions: ->
            | Peca ao colaborador para esclarecer se ele quer:
              - Tirar uma duvida sobre politica de RH (ex: regras de abono, home office, ferias CLT vs PJ)
              - Ou agendar suas proprias ferias (requer saldo vigente)
              Faca apenas UMA pergunta, curta e objetiva. Nao oferecer ajuda em temas fora de RH.
