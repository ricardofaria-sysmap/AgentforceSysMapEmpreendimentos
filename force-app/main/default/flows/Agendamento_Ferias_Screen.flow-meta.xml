<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <description>Screen Flow para agendamento de ferias do colaborador, invocado pelo Agentforce ou botao na home. Valida regras CLT, cria Case e submete aprovacao.</description>
    <environments>Default</environments>
    <interviewLabel>Agendamento Ferias {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Agendamento de Ferias (Screen)</label>
    <processType>Flow</processType>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <status>Active</status>

    <actionCalls>
        <name>Submit_Aprovacao</name>
        <label>Submeter para Aprovacao</label>
        <locationX>600</locationX>
        <locationY>1200</locationY>
        <actionName>FeriasApprovalSubmitter</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>Tela_Sucesso</targetReference>
        </connector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>caseId</name>
            <value>
                <elementReference>Criar_Case</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>comments</name>
            <value>
                <stringValue>Submetido via Agentforce (Screen Flow Agendamento_Ferias_Screen).</stringValue>
            </value>
        </inputParameters>
    </actionCalls>

    <assignments>
        <name>Set_Datas_Vars</name>
        <label>Copiar inputs de datas para variables</label>
        <locationX>600</locationX>
        <locationY>560</locationY>
        <assignmentItems>
            <assignToReference>varDataInicio</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>dataInicio</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varDataRetorno</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>dataRetorno</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Valida_CLT</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Abono_Vars</name>
        <label>Copiar inputs de abono para variables</label>
        <locationX>500</locationX>
        <locationY>960</locationY>
        <assignmentItems>
            <assignToReference>varVenderAbono</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>venderAbono</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varDiasAbono</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>diasAbono</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Confirmacao</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Erro_Aviso_30d</name>
        <label>Erro: Aviso 30d</label>
        <locationX>200</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varMensagemErro</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Atencao: pela CLT, suas ferias devem ser comunicadas com no minimo 30 dias de antecedencia. A data de inicio escolhida nao atende este prazo. Escolha uma data a partir de 30 dias a contar de hoje.</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Erro</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Erro_Saldo</name>
        <label>Erro: Saldo insuficiente</label>
        <locationX>350</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varMensagemErro</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Voce nao tem saldo suficiente para a quantidade de dias solicitada. Reveja as datas ou consulte o RH.</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Erro</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Erro_Minimo_5</name>
        <label>Erro: Minimo 5 dias</label>
        <locationX>500</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varMensagemErro</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Pela CLT, cada periodo de ferias precisa ter no minimo 5 dias corridos. Aumente o intervalo entre as datas.</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Erro</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Erro_Concessivo</name>
        <label>Erro: Periodo Concessivo</label>
        <locationX>650</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varMensagemErro</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>A data de retorno ultrapassa o periodo concessivo (12 meses apos o fim do periodo aquisitivo). Escolha um retorno ate o prazo final ou contate o RH.</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Erro</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Erro_Dia_Semana</name>
        <label>Erro: Dia da semana</label>
        <locationX>800</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varMensagemErro</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Pela CLT (art. 134, paragrafo 3), as ferias nao podem comecar em sexta, sabado ou domingo. Escolha um dia util de segunda a quinta para iniciar.</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Erro</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Erro_Vespera_Feriado</name>
        <label>Erro: Vespera de Feriado</label>
        <locationX>950</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varMensagemErro</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Pela CLT (art. 134, paragrafo 3), as ferias nao podem comecar nos 2 dias que antecedem um feriado. Escolha uma data de inicio mais afastada do proximo feriado.</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Tela_Erro</targetReference>
        </connector>
    </assignments>

    <decisions>
        <name>Decision_Saldo_Existe</name>
        <label>Existe Saldo Vigente?</label>
        <locationX>600</locationX>
        <locationY>200</locationY>
        <defaultConnector>
            <targetReference>Tela_Sem_Saldo</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Nao encontrou</defaultConnectorLabel>
        <rules>
            <name>Tem_Saldo</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Saldo_Atual.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Manager</targetReference>
            </connector>
            <label>Tem saldo</label>
        </rules>
    </decisions>

    <decisions>
        <name>Valida_CLT</name>
        <label>Validacoes CLT</label>
        <locationX>600</locationX>
        <locationY>500</locationY>
        <defaultConnector>
            <targetReference>Decision_Abono</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>OK</defaultConnectorLabel>
        <rules>
            <name>R1_Aviso_30d</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxDiasAteInicio</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>30.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Aviso_30d</targetReference>
            </connector>
            <label>Aviso 30d</label>
        </rules>
        <rules>
            <name>R2_Saldo_Insuficiente</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxDiasSolicitados</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Saldo_Atual.Dias_Disponiveis__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Saldo</targetReference>
            </connector>
            <label>Saldo insuficiente</label>
        </rules>
        <rules>
            <name>R3_Minimo_5</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxDiasSolicitados</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Minimo_5</targetReference>
            </connector>
            <label>Minimo 5 dias</label>
        </rules>
        <rules>
            <name>R4_Concessivo</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varDataRetorno</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Saldo_Atual.Periodo_Concessivo_Fim__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Concessivo</targetReference>
            </connector>
            <label>Fora do concessivo</label>
        </rules>
        <rules>
            <name>R5_Dia_Semana_Invalido</name>
            <conditionLogic>1 OR 2 OR 3</conditionLogic>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>6.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fxDiaSemanaInicio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>7.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Dia_Semana</targetReference>
            </connector>
            <label>Sex/Sab/Dom</label>
        </rules>
        <rules>
            <name>R6_Vespera_Feriado</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxVesperaFeriado</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Erro_Vespera_Feriado</targetReference>
            </connector>
            <label>Vespera de feriado</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_Abono</name>
        <label>Pode vender abono?</label>
        <locationX>600</locationX>
        <locationY>800</locationY>
        <defaultConnector>
            <targetReference>Tela_Confirmacao</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Limite atingido</defaultConnectorLabel>
        <rules>
            <name>Pode_Vender</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fxLimiteAbono</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Tela_Abono</targetReference>
            </connector>
            <label>Pode oferecer abono</label>
        </rules>
    </decisions>

    <formulas>
        <name>fxDiasSolicitados</name>
        <dataType>Number</dataType>
        <expression>{!varDataRetorno} - {!varDataInicio} + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxDiasAteInicio</name>
        <dataType>Number</dataType>
        <expression>{!varDataInicio} - TODAY()</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxLimiteAbono</name>
        <dataType>Number</dataType>
        <expression>FLOOR({!Get_Saldo_Atual.Dias_Direito__c} / 3) - BLANKVALUE({!Get_Saldo_Atual.Dias_Abono_Vendidos__c}, 0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxDiaSemanaInicio</name>
        <dataType>Number</dataType>
        <expression>WEEKDAY({!varDataInicio})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fxVesperaFeriado</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    {!varDataInicio} + 1 = DATE(2026,4,21),
    {!varDataInicio} + 2 = DATE(2026,4,21),
    {!varDataInicio} + 1 = DATE(2026,5,1),
    {!varDataInicio} + 2 = DATE(2026,5,1),
    {!varDataInicio} + 1 = DATE(2026,9,7),
    {!varDataInicio} + 2 = DATE(2026,9,7),
    {!varDataInicio} + 1 = DATE(2026,10,12),
    {!varDataInicio} + 2 = DATE(2026,10,12),
    {!varDataInicio} + 1 = DATE(2026,11,2),
    {!varDataInicio} + 2 = DATE(2026,11,2),
    {!varDataInicio} + 1 = DATE(2026,11,15),
    {!varDataInicio} + 2 = DATE(2026,11,15),
    {!varDataInicio} + 1 = DATE(2026,12,25),
    {!varDataInicio} + 2 = DATE(2026,12,25),
    {!varDataInicio} + 1 = DATE(2027,1,1),
    {!varDataInicio} + 2 = DATE(2027,1,1)
)</expression>
    </formulas>
    <formulas>
        <name>fxAssuntoCase</name>
        <dataType>String</dataType>
        <expression>"Pedido de Ferias - " &amp; TEXT({!varDataInicio}) &amp; " a " &amp; TEXT({!varDataRetorno})</expression>
    </formulas>
    <formulas>
        <name>fxDataLembrete</name>
        <dataType>Date</dataType>
        <expression>{!varDataInicio} - 5</expression>
    </formulas>

    <recordLookups>
        <name>Get_Saldo_Atual</name>
        <label>Buscar Saldo Vigente</label>
        <locationX>600</locationX>
        <locationY>100</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_Saldo_Existe</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Colaborador__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varUserId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Vigente</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Saldo_Ferias__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>

    <recordLookups>
